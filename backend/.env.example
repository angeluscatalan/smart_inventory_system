# Supabase / PostgreSQL connection string
# Use the Transaction pooler URL (port 6543) for runtime connections
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL — used by Prisma for migrations only
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Secret key used to sign JWT tokens — change this in production!
JWT_SECRET="your-secret-key-here"

# Allowed CORS origin(s) — comma-separated for multiple origins
CORS_ORIGIN="http://localhost:3000"

# JWT token expiry duration (e.g., 8h, 1d, 7d)
JWT_EXPIRES_IN="8h"
